# Local development defaults
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

POSTGRES_DB=intex
POSTGRES_USER=intex
POSTGRES_PASSWORD=<set-a-strong-local-password>
CONNECTIONSTRINGS__DEFAULTCONNECTION=Host=postgres;Port=5432;Database=intex;Username=intex;Password=<set-a-strong-local-password>

# Optional: absolute path to CSV snapshot for startup seed (defaults in appsettings.json). Docker Compose sets Seed__CsvPath=/data/lighthouse_csv_v7 with a volume mount.
# Seed__CsvPath=

# Use a long random value in real deployments. Production startup now fails if this is weak.
JWT__KEY=<set-a-long-random-jwt-key-at-least-32-bytes>
JWT__ISSUER=http://localhost:8080
JWT__AUDIENCE=http://localhost:5173

# CORS and CSP production helpers
CORS__ALLOWEDORIGINS__0=http://localhost:5173
PUBLIC_API_HOSTNAME=http://localhost:8080
FRONTEND__BASEURL=http://localhost:5173
ALLOWED_HOSTS=localhost;127.0.0.1

# Optional Google sign-in
AUTHENTICATION__GOOGLE__CLIENTID=
AUTHENTICATION__GOOGLE__CLIENTSECRET=

# Frontend
VITE_API_URL=http://localhost:8080/api
