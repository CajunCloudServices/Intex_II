{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:4173"
    ]
  },
  "Csp": {
    "ImgSrcAllowlist": [
      "https://fonts.gstatic.com"
    ]
  },
  "MlInference": {
    "BaseUrl": "http://localhost:8000",
    "ReintegrationEndpoint": "/predict/reintegration",
    "TimeoutSeconds": 10,
    "EnableLocalFallback": true
  },
  "Seed": {
    "Mode": "Csv",
    "ImportCsvOnStartup": true,
    "CsvPath": "../../ml-pipelines/lighthouse_csv_v7"
  },
  "DonationImpact": {
    "ProgramAreaUnitCosts": {
      "Education": 150,
      "Wellbeing": 200,
      "Operations": 50,
      "Transport": 300
    },
    "ProgramAreaOutcomeUnits": {
      "Education": "school kits",
      "Wellbeing": "counseling sessions",
      "Operations": "meal equivalents",
      "Transport": "home visitation trips"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ForwardedHeaders": {
    "KnownProxyIPs": [],
    "KnownNetworks": []
  }
}
